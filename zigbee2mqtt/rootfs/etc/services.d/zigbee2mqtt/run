#!/usr/bin/with-contenv bashio

# Read config
DATA_PATH=$(bashio::config 'data_path')
MQTT_BASE_TOPIC=$(bashio::config 'mqtt_base_topic')
MQTT_SERVER=$(bashio::config 'mqtt_server')
SERIAL_PORT=$(bashio::config 'serial_port')
SERIAL_ADAPTER=$(bashio::config 'serial_adapter')
PERMIT_JOIN=$(bashio::config 'permit_join')

# Create data directory
mkdir -p "$DATA_PATH"

# Generate configuration.yaml if not exists
CONFIG_FILE="$DATA_PATH/configuration.yaml"
if [ ! -f "$CONFIG_FILE" ]; then
    bashio::log.info "Creating initial Zigbee2MQTT configuration..."
    cat > "$CONFIG_FILE" <<EOF
homeassistant: true
permit_join: ${PERMIT_JOIN}

mqtt:
  base_topic: ${MQTT_BASE_TOPIC}
  server: ${MQTT_SERVER}

serial:
  port: ${SERIAL_PORT}
  adapter: ${SERIAL_ADAPTER}

frontend:
  port: 8080

advanced:
  network_key: GENERATE
  pan_id: GENERATE
  ext_pan_id: GENERATE

availability:
  active:
    timeout: 10
  passive:
    timeout: 1500

device_options: {}
EOF
fi

# Ensure data directory is linked
if [ ! -d "/app/data" ]; then
    mkdir -p /app
fi
if [ ! -L "/app/data" ]; then
    ln -sf "$DATA_PATH" /app/data
fi

bashio::log.info "Starting Zigbee2MQTT..."
bashio::log.info "Data path: $DATA_PATH"
bashio::log.info "Serial port: $SERIAL_PORT"
bashio::log.info "MQTT server: $MQTT_SERVER"

cd /app
exec /usr/bin/node index.js
